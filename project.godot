; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="CookieEmulator"
run/main_scene="uid://c0nqedjsprihf"
config/features=PackedStringArray("4.7", "C#", "Forward Plus")
run/max_fps=60
boot_splash/stretch_mode=3
boot_splash/image="uid://cemeji6cwjbkw"
config/icon="res://logo.png"

[autoload]

EmulatorManager="*uid://blebodrbh30y4"
Console="*uid://ouiu5xh1cs8n"
TapAssetExtractor="*uid://cpxxxxpedbu3c"

[display]

window/size/viewport_width=1024
window/size/viewport_height=768
window/stretch/mode="canvas_items"

[dotnet]

project/assembly_name="CookieEmulator"

[editor_plugins]

enabled=PackedStringArray("res://addons/console/plugin.cfg")

[file_customization]

folder_colors={
"res://objects/Components/": "gray"
}

